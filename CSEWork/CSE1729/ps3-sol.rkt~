;5a Golden Ratio by continued fractions

(define (golden n)
  (if (> n 0)
      (+ 1 (/ 1 (golden (- n 1))))
      1)
)

;5b Golden Ratio by continued square root

(define (golden-sqrt n)
  (if (> n 0)
      (sqrt (+ 1 (golden-sqrt (- n 1))))
      1)
)

