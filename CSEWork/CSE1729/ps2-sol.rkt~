(define (piecewise x)
  (define pi 3.142)
  (cond ((> x (* pi 2))
         (- x (* pi 2)))
        ((<= (* -1 pi) x)
         (sin x))
        ((< x (* -1 pi))
         (- (* -1 x) pi)))
)

