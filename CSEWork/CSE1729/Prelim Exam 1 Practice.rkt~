(define (improve g)
  (/ (+ (* g g) 1) (- (* 2 g) 1))
)

;b

(define (phi-help k n an)
  (if (< k n)
      (phi-help (+ k 1) n (improve an))
      an)
)

(define (phi-approximant n)
  (phi-help 0 n 1)
)

