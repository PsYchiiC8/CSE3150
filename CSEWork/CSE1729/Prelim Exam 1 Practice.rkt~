;b

(define (iradius A B C)
  (let ((S (/ (+ A B C) 2)))
    (sqrt (/ (* (- S A) (- S B) (- S C)) S)))
)

;c

(define (harmonic n)
  (if (> n 1)
      (+ (/ 1 n) (harmonic (- n 1)))
      1)
)

;d

(define (reciprocals n)
  (if (and (prime? n) (> n 1))
      (+ (/ 1 n) (reciprocals (- n 1)))
      (if (< n 2)
          0
          (reciprocals (- n 1))))
)


